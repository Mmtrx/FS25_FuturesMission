<?xml version="1.0" encoding="utf-8" standalone="no"?>
<!--=====================================================================================================
	Futures Mission GUI: start a contract
	Author:		Mmtrx		
	Changelog:
	 v1.0.0.0	22.03.2026	initial FS25
												can use $preset.. only in Profiles!
======================================================================================================-->
<GUI name="startContract" onOpen="onOpen" >
<!-- futures mission start selection dialog -->
<GuiElement profile="newLayer"/>
<Bitmap profile="dialogFullscreenBg" id="dialogBg"/>

<GuiElement profile="fs25_dialogBg" size="741px 400px" position="0px 0px" id="dialogElement">
	<ThreePartBitmap profile="fs25_dialogBgMiddleSmall"/>
	<ThreePartBitmap profile="fs25_dialogBgTopSmall"/>
	<ThreePartBitmap profile="fs25_dialogBgBottom"/>
	<GuiElement profile="fs25_dialogContentContainer" debugEnabled="false" >
		<Text profile="fs25_dialogTitle" position="0px -30px" text="start futures contract"/>

		<!-- quantity selection box -->
		<ThreePartBitmap profile="FMback" id="numAnimalsBoxBg" pos ="12px -90px" debugEnabled="false" />
		<GuiElement profile="fs25_animalAmountSelectorBox" id="numAnimalsBox" pos ="12px -104px" >
			<Text profile="fs25_animalAmountSelectorTitle" text="Amount committed" />
			<Bitmap profile="fs25_animalAmountSelectorSeparator" />
			<MultiTextOption profile="fs25_animalAmountSelector" id="multiTextAmount" onClick="onClickAmount" />
			<!--onFocus="onFocusNumAnimals" onLeave="onFocusTargetSelection" -->
		</GuiElement>

		<!-- info display: -->
		<GuiElement profile="fs25_animalInfoBox" id="infoBox" size="340px 250px">
		 <Text profile="fs25_animalMoneyTitle" position="10px 220px" text="Crop" />
		 <Text profile="fs25_animalMoneyValue" position="-10px 220px" text="0" id="infoCrop" />

		 <Bitmap profile="fs25_animalMoneyBg" position="0px 184px" />
		 <Text profile="fs25_animalMoneyTitle" position="10px 190px" text="Deliver by" />
		 <Text profile="fs25_animalMoneyValue" position="-10px 190px" text="0" id="infoMonth" />

		 <Text profile="fs25_animalMoneyTitle" position="10px 160px" text="Amount" />
		 <Text profile="fs25_animalMoneyValue" position="-10px 160px" text="0" id="infoAmount" />

		 <Bitmap profile="fs25_animalMoneyBg" position="0px 124px" />
		 <Text profile="fs25_animalMoneyTitle" position="10px 130px" text="Locked price" />
		 <Text profile="fs25_animalMoneyValue" position="-10px 130px" text="0" id="infoPrice" />

		 <Text profile="fs25_animalMoneyTitle" position="10px 100px" text="Change from base" />
		 <Text profile="fs25_animalMoneyValue" position="-10px 100px" text="0" id="infoChange" />
		 
		 <Bitmap profile="fs25_animalMoneyTotalBg" position="0px 54px" />
		 <Text profile="fs25_animalMoneyTotalTitle" position="10px 59px" text="Reward" />
		 <Text profile="fs25_animalMoneyTotalValue" position="-10px 59px" text="0" id="infoTotal" />
		 <Bitmap profile="FMiconPlus" id="iconHint" />
		 <Text profile="fs25_animalInfo" size="300px 30px" id="hint" textVerticalAlignment="center" text="set by lua" />
		</GuiElement>
	</GuiElement>
	
	<!-- std bottom menu -->
	<BoxLayout profile="fs25_dialogButtonBox" >
		<Button profile="buttonBack" text="$l10n_button_back" onClick="futuresClickButton" id="noButton"/>
		<Bitmap profile="fs25_dialogButtonBoxSeparator"/>
		<Button profile="buttonOK" text="$l10n_button_ok" onClick="futuresClickButton" id="yesButton"/>
	</BoxLayout>
</GuiElement>

<!-- profiles -->
<GUIProfiles>
	<Profile name="FMback" extends="fs25_animalAmountSelectorBoxBg" >
		<imageColor value="$preset_colorWhite" />
		<startImageColor value="$preset_colorWhite" />
		<endImageColor value="$preset_colorWhite" />
	</Profile>
	<Profile name="FMiconPlus" extends="fs25_animalInfoIcon" >
		<position value="0px 10px" />
	</Profile>
	<Profile name="FMiconMinus" extends="FMiconPlus" >
		<imageColor value="$preset_colorRed" />
    <imageSliceId value="gui.roundButtonExclamation" />
	</Profile>
	<Profile name="FMiconNeutral" extends="FMiconPlus" >
		<imageColor value="$preset_fs25_colorMainLight" />
    <imageSliceId value="gui.roundButtonSwap" />
	</Profile>

</GUIProfiles>
</GUI>
